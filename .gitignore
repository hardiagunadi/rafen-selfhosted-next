# Dependencies
/vendor
/node_modules

# Local environment
/.env
/.env.*
!/.env.example
/.phpunit.result.cache
/.codex-memory.md
/.DS_Store
/Thumbs.db

# Build and public runtime assets
/public/build
/public/storage
/public/wato/cron.log
/public/wato/wato.db

# Bootstrap cache
/bootstrap/cache/*
!/bootstrap/cache/.gitignore

# Storage runtime artifacts
/storage/*.key
/storage/app/*
!/storage/app/.gitignore
!/storage/app/license/
/storage/app/license/*
!/storage/app/license/.gitignore
/storage/framework/cache/*
!/storage/framework/cache/data/
!/storage/framework/cache/data/.gitignore
/storage/framework/sessions/*
!/storage/framework/sessions/.gitignore
/storage/framework/views/*
!/storage/framework/views/.gitignore
/storage/framework/testing-machine-id
/storage/logs/*
!/storage/logs/.gitignore

# Package manager logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Generated self-hosted workspace artifacts
/_self_hosted_*.json
